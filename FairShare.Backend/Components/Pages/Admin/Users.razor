@page "/admin/users"
@using global::FairShare.Shared.ViewModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "AdminOnly")]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>FairShare - User Management</PageTitle>

<div class="container my-4">
    <h2>Users</h2>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="() => message = null" aria-label="Close"></button>
        </div>
    }

    <div class="mb-3 d-flex gap-2 align-items-center">
        <label for="filter" class="form-label mb-0">Filter:</label>
        <select @bind="filter" @bind:after="LoadUsers" id="filter" class="form-select" style="width: auto;">
            <option value="all">All</option>
            <option value="enabled">Enabled</option>
            <option value="disabled">Disabled</option>
        </select>
        <button class="btn btn-primary ms-auto" @onclick="CreateUser">
            <i class="bi bi-plus-circle"></i> New User
        </button>
    </div>

    @if (users == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>UserName</th>
                        <th>Role</th>
                        <th>Created</th>
                        <th>Last Seen</th>
                        <th>Updated</th>
                        <th>Disabled</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in users)
                    {
                        <tr>
                            <td>@u.UserName</td>
                            <td>@u.Role</td>
                            <td>@u.CreatedUtc.ToLocalTime().ToString("g")</td>
                            <td>@(u.LastSeenUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                            <td>@(u.UpdatedUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                            <td>
                                <span class="badge bg-@(u.IsDisabled ? "danger" : "success")">
                                    @(u.IsDisabled ? "Yes" : "No")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditUser(u.Id)" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u.Id)" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<UserListItemViewModel>? users;
    private string filter = "all";
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await Http.GetFromJsonAsync<List<UserListItemViewModel>>($"api/admin/users?filter={filter}");
    }

    private void CreateUser() => Navigation.NavigateTo("/admin/users/create");
    private void EditUser(Guid id) => Navigation.NavigateTo($"/admin/users/edit/{id}");

    private async Task DeleteUser(Guid id)
    {
        // Simple confirm for now
        var confirmed = true; // In real app, use a JS interop confirm or a modal
        if (confirmed)
        {
            var response = await Http.DeleteAsync($"api/admin/users/{id}");
            if (response.IsSuccessStatusCode)
            {
                message = "User deleted successfully.";
                await LoadUsers();
            }
            else
            {
                // Handle error
            }
        }
    }
}
