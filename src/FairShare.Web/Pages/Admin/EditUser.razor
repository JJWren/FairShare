@page "/admin/users/edit/{Id:guid}"
@using FairShare.Contracts.Admin
@attribute [Authorize(Policy = "AdminOnly")]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>FairShare - Edit User</PageTitle>

<div class="container my-4">
    <h2>Edit User</h2>

    @if (errors.Any())
    {
        <div class="alert alert-danger">
            <ul>
                @foreach (var error in errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    @if (model == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-6">
                <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="editUserForm">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label for="userName" class="form-label">UserName</label>
                        <InputText id="userName" @bind-Value="model.UserName" class="form-control" />
                        <ValidationMessage For="() => model.UserName" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label for="role" class="form-label">Role</label>
                        <InputSelect id="role" @bind-Value="model.Role" class="form-select">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </InputSelect>
                        <ValidationMessage For="() => model.Role" class="text-danger" />
                    </div>

                    <div class="mb-3 form-check">
                        <InputCheckbox id="isDisabled" @bind-Value="model.IsDisabled" class="form-check-input" />
                        <label class="form-check-label" for="isDisabled">Disabled</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private EditUserRequest? model;
    private List<string> errors = new();

    protected override async Task OnInitializedAsync()
    {
        model = await Http.GetFromJsonAsync<EditUserRequest>($"api/v1/admin/users/{Id}");
    }

    private async Task HandleSubmit()
    {
        if (model == null) return;
        errors.Clear();
        var response = await Http.PutAsJsonAsync($"api/v1/admin/users/{Id}", model);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/admin/users");
        }
        else
        {
            errors.Add("Failed to update user.");
        }
    }

    private void Cancel() => Navigation.NavigateTo("/admin/users");
}
