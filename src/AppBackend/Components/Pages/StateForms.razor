@page "/States/{State}"
@using FairShare.AppShared.Interfaces
@inject IStateGuidelineCatalog Catalog
@inject NavigationManager Navigation

<PageTitle>FairShare - @State Forms</PageTitle>

<div class="container my-5">
    <h1 class="h4 mb-4 text-center">Forms Available for @State</h1>

    @if (forms is null)
    {
        <p class="text-center">Loading forms...</p>
    }
    else if (!forms.Any())
    {
        <div class="alert alert-warning">No forms registered for this state.</div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-12 col-sm-6 col-md-4">
                <div class="mb-3">
                    <label class="form-label" for="selectedForm">Select Form</label>
                    <select id="selectedForm" @bind="selectedForm" class="form-select">
                        <option value="">-- choose --</option>
                        @foreach (var f in forms)
                        {
                            <option value="@f.Form">@f.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="text-center mt-3">
                    <button class="btn btn-primary" @onclick="Continue">Continue</button>
                </div>
            </div>
        </div>
    }

    <div class="text-center mt-4">
        <a href="/" class="btn btn-link">&larr; Back to States</a>
    </div>
</div>

@code {
    [Parameter]
    public string State { get; set; } = string.Empty;

    private IEnumerable<(string Form, string DisplayName)>? forms;
    private string? selectedForm;

    protected override void OnParametersSet()
    {
        forms = Catalog.GetFormsForState(State);
        selectedForm = forms.FirstOrDefault().Form;
    }

    private void Continue()
    {
        if (!string.IsNullOrEmpty(selectedForm))
        {
            Navigation.NavigateTo($"/States/{State}/{selectedForm}");
        }
    }
}




