@implements IDisposable
@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom mb-4">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">⚖️ FairShare</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <AuthorizeView>
                    <Authorized>
                        @if (!context.User.HasClaim("guest", "true"))
                        {
                            <li class="nav-item">
                                <NavLink class="nav-link" href="parents">Parents</NavLink>
                            </li>
                        }
                    </Authorized>
                </AuthorizeView>
            </ul>
            <ul class="navbar-nav ms-auto align-items-center">
                <AuthorizeView>
                    <Authorized>
                        @if (context.User.HasClaim("guest", "true"))
                        {
                            <li class="nav-item">
                                <span class="nav-link text-muted" title="Guest mode: limited functionality">
                                    <small>Guest</small>
                                </span>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <NavLink class="nav-link" href="Account/Manage" title="Settings">
                                    <i class="bi bi-gear"></i>
                                </NavLink>
                            </li>
                        }
                        <li class="nav-item">
                            <a href="Account/Logout" class="btn btn-link nav-link">
                                Logout
                            </a>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="Account/Login">Login</NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="Account/Guest" title="Guest mode disables saving, settings, and user management.">
                                Guest
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
