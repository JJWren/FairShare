{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "FairShare": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=/app/data/fairshare.db"
  },
  "Jwt": {
    "Issuer": "FairShare.Api",
    "Audience": "FairShare.Web",
    "SigningKey": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AdminSeed": {
    "Enabled": true,
    "User": "admin",
    "Password": "",
    "LogGeneratedPassword": true
  }
}
