@page "/States/{State}/{Form}"
@using FairShare.Shared.Interfaces
@using FairShare.Shared.Models
@using FairShare.Shared.ViewModels
@using FairShare.Client.Components
@inject IStateGuidelineCatalog Catalog
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>FairShare - @State - @Form Calculator</PageTitle>

<div class="container my-4">
    <h1 class="h4 mb-3 text-center">@State - @Form Calculator</h1>

    <div class="row g-3 mb-4 justify-content-center">
        <div class="col-12 col-sm-5 col-lg-3 text-center">
            <label class="form-label" for="NumberOfChildren">Number of Children</label>
            <input type="number" @bind="vm.NumberOfChildren" class="form-control" />
        </div>
    </div>

    @if (vm.Form.Equals("CS42", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-info py-2 small text-center">
            Mark exactly one parent as having Primary Custody.
        </div>
    }

    <div class="row g-4">
        <ParentCard Title="Plaintiff" 
                    Prefix="Plaintiff" 
                    Data="vm.Plaintiff" 
                    ParentName="@vm.PlaintiffName" 
                    ShowPrimary="@(vm.Form.Equals("CS42", StringComparison.OrdinalIgnoreCase))"
                    SavedProfiles="savedProfiles" />

        <ParentCard Title="Defendant" 
                    Prefix="Defendant" 
                    Data="vm.Defendant" 
                    ParentName="@vm.DefendantName" 
                    ShowPrimary="@(vm.Form.Equals("CS42", StringComparison.OrdinalIgnoreCase))"
                    SavedProfiles="savedProfiles" />
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" @onclick="Calculate">Calculate</button>
        <button class="btn btn-outline-secondary" @onclick="Reset">Reset</button>
    </div>

    @if (errors.Any())
    {
        <div class="mt-3">
            <ul class="text-danger">
                @foreach (var error in errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="mt-5">
        <div class="card shadow-sm">
            <div class="card-header text-center"><strong>Results</strong></div>
            <div class="card-body">
                @if (vm.Submitted && vm.Result is not null && vm.Result.Success)
                {
                    <p class="fw-bold text-center mb-0">
                        @(string.IsNullOrWhiteSpace(vm.Result.Payer)
                            ? "No net transfer."
                            : $"{vm.Result.Payer} owes ${vm.Result.FinalAmount}.")
                    </p>
                }
                else if (vm.Submitted && vm.Result is not null && !vm.Result.Success)
                {
                    <ul class="text-danger mb-0">
                        @foreach (var e in vm.Result.Errors)
                        {
                            <li>@e.Code: @e.Message</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">Enter inputs and Calculate.</p>
                }
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@($"/States/{State}")" class="btn btn-link">&larr; Back to @State Forms</a>
    </div>
</div>

@code {
    [Parameter] public string State { get; set; } = string.Empty;
    [Parameter] public string Form { get; set; } = string.Empty;

    private CalculatorViewModel vm = new();
    private List<ParentProfile>? savedProfiles;
    private List<string> errors = new();

    protected override async Task OnInitializedAsync()
    {
        vm.State = State;
        vm.Form = Form;
        
        try 
        {
            savedProfiles = await Http.GetFromJsonAsync<List<ParentProfile>>("api/parents");
        }
        catch 
        {
            // Possibly not logged in or guest
        }
    }

    private void Calculate()
    {
        errors.Clear();
        var calc = Catalog.GetCalculator(State, Form);
        if (calc == null)
        {
            errors.Add("Calculator not found.");
            return;
        }

        if (vm.Form.Equals("CS42", StringComparison.OrdinalIgnoreCase))
        {
            if (vm.Plaintiff.HasPrimaryCustody == vm.Defendant.HasPrimaryCustody)
            {
                errors.Add("For this form, you must mark exactly one parent as having Primary Custody.");
                return;
            }
        }

        vm.Result = calc.Calculate(vm.Plaintiff, vm.Defendant, vm.NumberOfChildren);
        vm.Submitted = true;
        
        // Note: In the MVC version, it also called _parentService.GetOrCreateAsync.
        // In Blazor WASM, we should call the API to save the parent profiles if success.
        if (vm.Result.Success)
        {
            SaveParents();
        }
    }

    private async void SaveParents()
    {
        // Call API to save parents if names are provided
        if (!string.IsNullOrWhiteSpace(vm.PlaintiffName))
        {
            await Http.PostAsJsonAsync("api/parents", new { 
                DisplayName = vm.PlaintiffName,
                vm.Plaintiff.MonthlyGrossIncome,
                vm.Plaintiff.PreexistingChildSupport,
                vm.Plaintiff.PreexistingAlimony,
                vm.Plaintiff.WorkRelatedChildcareCosts,
                vm.Plaintiff.HealthcareCoverageCosts,
                vm.Plaintiff.HasPrimaryCustody
            });
        }
        
        if (!string.IsNullOrWhiteSpace(vm.DefendantName))
        {
            await Http.PostAsJsonAsync("api/parents", new { 
                DisplayName = vm.DefendantName,
                vm.Defendant.MonthlyGrossIncome,
                vm.Defendant.PreexistingChildSupport,
                vm.Defendant.PreexistingAlimony,
                vm.Defendant.WorkRelatedChildcareCosts,
                vm.Defendant.HealthcareCoverageCosts,
                vm.Defendant.HasPrimaryCustody
            });
        }
    }

    private void Reset()
    {
        vm = new CalculatorViewModel { State = State, Form = Form };
        errors.Clear();
    }
}
